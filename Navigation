css
body{
    margin:0;
    font-family: Arial;
}

.navbar{
    background-color: #333;
    overflow: hidden;
}

.navbar a{
    float: left;
    color: white;
    text-align: center;
    padding: 14px 20px;
    text-decoration: none;
    font-size: 18px;
}

.navbar a:hover{
    background-color: #ddd;
    color: black;
}
